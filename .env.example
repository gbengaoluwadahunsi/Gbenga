# --- Portfolio AI assistant (optional) ---
# Leave these unset and the assistant works with the built-in rule-based
# responder. Add a key to upgrade it to a real reasoning LLM.
#
# Recommended: Groq (free tier, no card required) — https://console.groq.com/keys
# The API is OpenAI-compatible, so DeepSeek / OpenAI also work by changing
# LLM_BASE_URL and LLM_MODEL below.

# Groq (default)
LLM_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# DeepSeek (alternative)
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# OpenAI (alternative)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
